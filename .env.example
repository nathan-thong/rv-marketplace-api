# Rails Environment
RAILS_ENV=development
RAILS_MAX_THREADS=5
PORT=3000

# Rails master key — copy the value from config/master.key
# Required when running in production (including docker-compose)
RAILS_MASTER_KEY=

# Database
# For local PostgreSQL with default settings, this should work:
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/rv_marketplace_development

# JWT Secret (for token-based authentication)
# Generate with: bundle exec rails secret
JWT_SECRET=replace-with-long-random-secret-key-generated-by-rails-secret

# Job Processing (optional)
JOB_CONCURRENCY=1
SOLID_QUEUE_IN_PUMA=false